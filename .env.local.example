# Copy to .env.local and fill in. The app runs in "demo mode" without these,
# but the REAL AI tutor + translation need Vercel AI Gateway auth.

# Vercel AI Gateway (required for live AI tutor + translation). Get a key at
# https://vercel.com/<team>/<project>/settings/ai — or run `vercel env pull`
# on a linked project to provision VERCEL_OIDC_TOKEN automatically instead.
AI_GATEWAY_API_KEY=...

# Optional model overrides — any Gateway "provider/model" slug works here,
# e.g. openai/gpt-5.4, google/gemini-3-flash, deepseek/deepseek-v3.2:
# AI_MODEL=anthropic/claude-opus-4.8
# AI_TRANSLATE_MODEL=anthropic/claude-sonnet-5

# Supabase (Phase 3 — auth, roles, storage, pgvector). Optional for the demo.
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...

# Sentry (error tracking). Both no-op — nothing is initialized — until set.
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# Langfuse (LLM observability — traces every /api/tutor and /api/translate
# call). No-ops until both keys are set. Get them from a Langfuse project's
# Settings > API Keys.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
